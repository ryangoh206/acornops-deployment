################################################################################
# Local Stack Ports
################################################################################

CONTROL_PLANE_PORT=8081
EXECUTION_ENGINE_PORT=8080
LLM_GATEWAY_PORT=8001
MOCK_MCP_PORT=8002
KEYCLOAK_PORT=8082
EDGE_PROXY_HTTP_PORT=8088

################################################################################
# Local Profiles & Kubernetes
################################################################################

# Local OIDC provider profile used by scripts (`oidc-dex` or `oidc-keycloak`).
LOCAL_OIDC_PROFILE=oidc-dex
# Optional extra compose profiles, space/comma separated (e.g. `local-vault`).
LOCAL_EXTRA_PROFILES=
# Local k3d bootstrap settings used by `task local-up`.
LOCAL_K3D_AUTO_CREATE=true
LOCAL_K3D_CLUSTER_NAME=acornops-demo-cluster
LOCAL_K8S_RUNTIME_DIR=/tmp/acornops-local-kube

################################################################################
# Hosts & Frontend Routing
################################################################################

API_HOST=acornops.localhost
MANAGEMENT_CONSOLE_HOST=console.acornops.localhost
CONTROL_PLANE_HOST=control-plane.acornops.localhost
LLM_GATEWAY_HOST=llm-gateway.acornops.localhost
EXECUTION_ENGINE_HOST=execution-engine.acornops.localhost
VITE_APP_BASE_PATH=/
VITE_APP_DATA_MODE=control-plane
# For local full-stack SSO, leave empty to use same-origin API path via the console host.
VITE_CONTROL_PLANE_API_BASE_URL=

################################################################################
# Frontend Watch Mode
################################################################################

CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

################################################################################
# Authentication / OIDC
################################################################################

OIDC_PROVIDER_NAME=dex
OIDC_ISSUER_URL=http://dex:5556/dex
OIDC_PUBLIC_ISSUER_URL=http://localhost:5556/dex
OIDC_CLIENT_ID=acornops-control-plane
OIDC_CLIENT_SECRET=acornops-control-plane-secret
OIDC_TOKEN_ENDPOINT_AUTH_METHOD=client_secret_basic
OIDC_AUTHORIZATION_ENDPOINT_OVERRIDE=http://localhost:5556/dex/auth
OIDC_TOKEN_ENDPOINT_OVERRIDE=http://dex:5556/dex/token
OIDC_USERINFO_ENDPOINT_OVERRIDE=http://dex:5556/dex/userinfo
OIDC_JWKS_URI_OVERRIDE=http://dex:5556/dex/keys
OIDC_REDIRECT_URI=http://console.acornops.localhost:8088/api/v1/auth/oidc/callback
OIDC_USE_USERINFO=true

################################################################################
# Local Images
################################################################################

MANAGEMENT_CONSOLE_IMAGE=acornops/management-console:local
CONTROL_PLANE_IMAGE=acornops/control-plane:local
EXECUTION_ENGINE_IMAGE=acornops/execution-engine:local
LLM_GATEWAY_IMAGE=acornops/llm-gateway:local

################################################################################
# Service Tokens & Local Passwords
################################################################################

ORCH_SERVICE_TOKEN=dev_orchestrator_token
EXTERNAL_INTEGRATION_CLIENTS_JSON='[{"id":"dev-client","provider":"external","displayName":"Development external integration","sha256":"c900e895f6e7b6358dcfc3c6e0cc24d275f3c413256911756c5150dd9f9fe222","enabled":true}]'
EXECUTION_ENGINE_DISPATCH_TOKEN=dev_execution_engine_dispatch_token
LLM_GATEWAY_ADMIN_TOKEN=dev_orchestrator_token
CP_REDIS_PASSWORD=dev_cp_redis_password
GATEWAY_REDIS_PASSWORD=dev_gateway_redis_password

################################################################################
# LLM Policy
################################################################################

LLM_GATEWAY_TIMEOUT_MS=120000
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-5.5
LLM_ALLOWED_PROVIDERS=openai,anthropic,gemini
LLM_ALLOWED_PROVIDER_MODELS='openai:gpt-5.5|gpt-5.4|gpt-5.4-mini|gpt-5.4-nano|gpt-5|gpt-5-mini|gpt-5-nano;anthropic:claude-fable-5|claude-opus-4-8|claude-sonnet-4-6|claude-haiku-4-5;gemini:gemini-3.5-flash|gemini-3.5-flash-lite|gemini-3.1-pro|gemini-3.1-flash|gemini-3.1-flash-lite|gemini-2.5-pro|gemini-2.5-flash|gemini-2.5-flash-lite|gemini-2.0-flash|gemini-2.0-flash-lite'
LLM_ALLOWED_MODELS=
LLM_ALLOWED_REASONING_EFFORTS=off,low,medium,high
LLM_ENABLE_DETERMINISTIC_DEV_RESPONSES=false

################################################################################
# Seeded Workspace AI Credentials
################################################################################

# Optional provider API keys copied into the demo workspace during local-up.
# Leave blank to start with the provider unconfigured.
ACORNOPS_DEV_SEED_OPENAI_API_KEY=
ACORNOPS_DEV_SEED_ANTHROPIC_API_KEY=
ACORNOPS_DEV_SEED_GEMINI_API_KEY=

################################################################################
# Agent Runtime Defaults
################################################################################

AGENT_SYSTEM_INSTRUCTION='You are AcornOps, a Kubernetes troubleshooting assistant. Use concise, safe recommendations and call available tools before answering questions about live cluster state.'
AGENT_CONTEXT_MAX_TOKENS=120000
AGENT_BUDGET_CENTS=25
AGENT_LLM_TEMPERATURE=0.2
AGENT_MAX_RUNTIME_MS=600000
AGENT_MAX_STEPS=16
AGENT_MAX_TOOL_CALLS=24
AGENT_MAX_DUPLICATE_TOOL_CALLS=2
AGENT_TOOL_DEFAULT_TIMEOUT_MS=10000
AGENT_HELM_RELEASE_NAME=acornops-agent
AGENT_HELM_CHART_REF=oci://ghcr.io/acornops/charts/acornops-agentk
AGENT_HELM_NAMESPACE=acornops

################################################################################
# Local Target Seeds
################################################################################

LOCAL_VM_TARGET_ID=9254df42-4d9b-4e63-8bb6-93442e7d9a45
LOCAL_VM_AGENT_KEY=ak_local_vm_dev_shared_key
ACORNOPS_VM_AGENT_SNAPSHOT_INTERVAL_MS=15000
ACORNOPS_VM_COLLECTOR_MODE=mock
ACORNOPS_VM_ALLOWED_LOG_SOURCES=journald,syslog

################################################################################
# Built-in MCP Server
################################################################################

BUILTIN_MCP_SERVER_NAME=acornops-cluster-agent
BUILTIN_MCP_SERVER_URL=http://control-plane:8081/internal/v1/mcp
BUILTIN_MCP_SERVER_DISPLAY_NAME='AcornOps Kubernetes Tools'

################################################################################
# Retention & Run Events
################################################################################

CONVERSATION_RETENTION_DAYS=30
CONVERSATION_RETENTION_JOB_INTERVAL_SECONDS=3600
RUN_EVENT_BUFFER_SIZE=200
PERSIST_RUN_EVENTS=false

################################################################################
# Control Plane Routing
################################################################################

CONTROL_PLANE_DISTRIBUTED_ROUTING_ENABLED=false
CONTROL_PLANE_AGENT_OWNER_TTL_SECONDS=90
AUTOMATION_RUNTIME_MODE=on
AUTOMATION_CANARY_WORKSPACE_IDS=
AUTOMATION_WORKER_INTERVAL_MS=1000

################################################################################
# Execution Durability
################################################################################

EXECUTION_ENGINE_REDIS_URL=redis://:dev_cp_redis_password@cp-redis:6379/1
EXECUTION_DURABILITY_REDIS_URL=redis://:dev_cp_redis_password@cp-redis:6379/1
EXECUTION_DURABILITY_KEY_PREFIX=execution-engine

################################################################################
# Terminal Runs
################################################################################

TERMINAL_RUN_TTL_SECONDS=3600
TERMINAL_COMMIT_RETENTION_SECONDS=86400
TERMINAL_COMMIT_RETRY_INTERVAL_SECONDS=5

################################################################################
# Secrets Backend / Vault
################################################################################

SECRETS_BACKEND=database
SECRETS_KEK_BASE64=SglIGBscu1EgQ+AlpqJLADNN9QmCzS9d1ZvK3oT/e5s=
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root
VAULT_NAMESPACE=
VAULT_MOUNT=secret
VAULT_PATH_PREFIX=acornops
VAULT_TIMEOUT_MS=5000
VAULT_VERIFY_TLS=false

################################################################################
# API Documentation
################################################################################

CP_ENABLE_API_DOCS=true
EE_ENABLE_API_DOCS=true
GW_ENABLE_API_DOCS=true

################################################################################
# Databases
################################################################################

CP_DB_USER=acornops
CP_DB_PASSWORD=acornops
CP_DB_NAME=acornops_control_plane

GATEWAY_DB_USER=gateway_user
GATEWAY_DB_PASSWORD=gateway_password
GATEWAY_DB_NAME=gateway

################################################################################
# Demo Data
################################################################################

SEED_DEMO_K3S_WORKLOADS=true
RESET_DEMO_K3S_WORKLOADS=true
DEMO_K8S_NAMESPACE=acornops-demo

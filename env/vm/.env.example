################################################################################
# Domains & Edge Routing
################################################################################

EDGE_PROXY_HTTP_PORT=80
BASE_DOMAIN=acornops.dev
API_HOST=api.acornops.dev
MANAGEMENT_CONSOLE_HOST=console.acornops.dev
MANAGEMENT_CONSOLE_UPSTREAM=management-console:8080
VITE_APP_BASE_PATH=/

################################################################################
# Production Images
################################################################################

MANAGEMENT_CONSOLE_IMAGE=ghcr.io/acornops/management-console:0.0.1-experimental.1
CONTROL_PLANE_IMAGE=ghcr.io/acornops/control-plane:0.0.1-experimental.2
EXECUTION_ENGINE_IMAGE=ghcr.io/acornops/execution-engine:0.0.1-experimental.1
LLM_GATEWAY_IMAGE=ghcr.io/acornops/llm-gateway:0.0.1-experimental.2

################################################################################
# Public & Internal Service Routing
################################################################################

CONTROL_PLANE_BASE_URL=https://api.acornops.dev
CORS_ORIGIN=https://console.acornops.dev
TRUST_PROXY=1
EXECUTION_ENGINE_BASE_URL=http://execution-engine:8080
LLM_GATEWAY_URL=http://llm-gateway:8001
ORCH_BASE_URL=http://control-plane:8081
EXECUTION_GATEWAY_BASE_URL=http://llm-gateway:8001
AUTH_JWKS_URL=http://control-plane:8081/api/v1/auth/jwks.json

################################################################################
# Runtime Environment
################################################################################

APP_ENV=production

# Optional host PEM bundle used with compose.additional-ca.yaml. This extends
# normal public trust for all server-side components and migration jobs.
ADDITIONAL_CA_BUNDLE_SOURCE_PATH=

################################################################################
# Authentication / OIDC
################################################################################

OIDC_ENABLED=true
OIDC_PROVIDER_NAME=keycloak
OIDC_ISSUER_URL=https://keycloak.acornops.dev/realms/acornops
OIDC_PUBLIC_ISSUER_URL=https://keycloak.acornops.dev/realms/acornops
OIDC_CLIENT_ID=acornops-control-plane
OIDC_CLIENT_SECRET=replace-me
OIDC_TOKEN_ENDPOINT_AUTH_METHOD=client_secret_basic
OIDC_AUTHORIZATION_ENDPOINT_OVERRIDE=
OIDC_TOKEN_ENDPOINT_OVERRIDE=
OIDC_USERINFO_ENDPOINT_OVERRIDE=
OIDC_JWKS_URI_OVERRIDE=
OIDC_END_SESSION_ENDPOINT_OVERRIDE=https://keycloak.acornops.dev/realms/acornops/protocol/openid-connect/logout
OIDC_REDIRECT_URI=https://console.acornops.dev/api/v1/auth/oidc/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://console.acornops.dev/api/v1/auth/oidc/logout/callback
OIDC_ADMISSION_POLICY_JSON='{"requireVerifiedEmail":true}'
OIDC_USE_USERINFO=true

################################################################################
# Password Auth & Email Delivery
################################################################################

PASSWORD_AUTH_ENABLED=true
PASSWORD_SIGNUP_ENABLED=false
PASSWORD_EMAIL_VERIFICATION_REQUIRED=true
PASSWORD_EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
PASSWORD_EMAIL_VERIFICATION_RESEND_WINDOW_SECONDS=300
PASSWORD_SIGNUP_ALLOW_UNVERIFIED_EMAIL=false
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
PASSWORD_RESET_REQUEST_WINDOW_SECONDS=300
PASSWORD_AUTH_IDENTIFIER_MAX_ATTEMPTS=50
EMAIL_DELIVERY_MODE=smtp
EMAIL_DELIVERY_ALLOW_LOG_IN_PRODUCTION=false
EMAIL_FROM="AcornOps <noreply@acornops.dev>"
EMAIL_PUBLIC_BASE_URL=https://console.acornops.dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true

################################################################################
# Required Secrets & Service Tokens
################################################################################

CSRF_SECRET=replace-me
ORCH_SERVICE_TOKEN=replace-me
EXTERNAL_INTEGRATION_CLIENTS_JSON='[{"id":"mattermost-eng","provider":"mattermost","displayName":"Mattermost Engineering","sha256":"c900e895f6e7b6358dcfc3c6e0cc24d275f3c413256911756c5150dd9f9fe222","enabled":true,"allowedCapabilities":["read_workspace_data","create_sessions","create_read_only_runs"]}]'
BUILTIN_MCP_SERVICE_TOKEN=replace-me
EXECUTION_ENGINE_DISPATCH_TOKEN=replace-me
LLM_GATEWAY_ADMIN_TOKEN=replace-me
WEBHOOK_SECRET_ENCRYPTION_KEY=replace-me-with-32-byte-base64
# Optional exact HTTPS hostnames that may resolve to private addresses.
# Example: WEBHOOK_EGRESS_ALLOWED_PRIVATE_HOSTS_JSON='["mattermost-bot.internal"]'
WEBHOOK_EGRESS_ALLOWED_PRIVATE_HOSTS_JSON=[]
# Durable delivery worker tuning. Disable claims during maintenance without
# disabling event enqueueing; re-enable it to drain the backlog.
WEBHOOK_WORKER_ENABLED=true
WEBHOOK_WORKER_BATCH_SIZE=50
WEBHOOK_WORKER_CONCURRENCY=20
WEBHOOK_WORKER_PER_ORIGIN_CONCURRENCY=4
WEBHOOK_MAX_ATTEMPTS=10
WEBHOOK_MAX_RETRY_AGE_SECONDS=86400
WEBHOOK_MAX_PAYLOAD_BYTES=65536
WEBHOOK_MAX_SUBSCRIPTIONS_PER_WORKSPACE=100
GATEWAY_SIGNING_KID=cp-rs256-1
GATEWAY_SIGNING_PRIVATE_KEY_PEM_B64=replace-me-with-rsa-private-key-base64
GATEWAY_VERIFICATION_JWKS_JSON=
SECRETS_KEK_BASE64=replace-me-with-32-byte-base64
CP_REDIS_PASSWORD=replace-me
GATEWAY_REDIS_PASSWORD=replace-me

################################################################################
# Admin API & Workspace Plans
################################################################################

CONTROL_PLANE_ADMIN_API_ENABLED=false
# JSON array of admin token hash descriptors. Never store raw admin tokens here.
CONTROL_PLANE_ADMIN_TOKENS_JSON=[]
CONTROL_PLANE_ADMIN_AUTH_FAILURE_WINDOW_SECONDS=300
CONTROL_PLANE_ADMIN_AUTH_FAILURE_MAX_ATTEMPTS=20
WORKSPACE_PLANS_CONFIG_JSON='{"defaultPlanKey":"default","plans":[{"key":"default","name":"Default","quotas":{"members":100,"kubernetesClusters":30,"virtualMachines":30}}]}'

################################################################################
# LLM Policy
################################################################################

LLM_GATEWAY_TIMEOUT_MS=120000
BUILTIN_MCP_MAX_RESPONSE_BYTES=3145728
REMOTE_MCP_ENABLED=true
MCP_CONNECTION_RATE_LIMIT_PER_WINDOW=10
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-5.5
LLM_ALLOWED_PROVIDERS=openai,anthropic,gemini
LLM_ALLOWED_PROVIDER_MODELS='openai:gpt-5.5|gpt-5.4|gpt-5.4-mini|gpt-5.4-nano|gpt-5|gpt-5-mini|gpt-5-nano;anthropic:claude-fable-5|claude-opus-4-8|claude-sonnet-4-6|claude-haiku-4-5;gemini:gemini-3.5-flash|gemini-3.5-flash-lite|gemini-3.1-pro|gemini-3.1-flash|gemini-3.1-flash-lite|gemini-2.5-pro|gemini-2.5-flash|gemini-2.5-flash-lite|gemini-2.0-flash|gemini-2.0-flash-lite'
LLM_ALLOWED_REASONING_EFFORTS=off,low,medium,high

################################################################################
# AI Assistant Runtime Defaults
################################################################################

ASSISTANT_SYSTEM_INSTRUCTION='You are AcornOps, an infrastructure troubleshooting assistant. Use concise, safe recommendations and call available tools before answering questions about live target state.'
ASSISTANT_CONTEXT_MAX_TOKENS=120000
ASSISTANT_BUDGET_CENTS=25
ASSISTANT_LLM_TEMPERATURE=0.2
ASSISTANT_MAX_RUNTIME_MS=600000
ASSISTANT_MAX_STEPS=16
ASSISTANT_MAX_TOOL_CALLS=24
ASSISTANT_MAX_DUPLICATE_TOOL_CALLS=2
ASSISTANT_TOOL_DEFAULT_TIMEOUT_MS=10000
ASSISTANT_WRITE_CONFIRMATION_REQUIRED=true
ASSISTANT_WRITE_CONFIRMATION_TIMEOUT_SECONDS=900

################################################################################
# AgentK Installation
################################################################################

AGENTK_HELM_RELEASE_NAME=acornops-agentk
AGENTK_HELM_CHART_REF=oci://ghcr.io/acornops/charts/acornops-agentk
AGENTK_HELM_CHART_VERSION=
AGENTK_HELM_NAMESPACE=acornops-agentk
AGENTK_HELM_VALUES_JSON={}
AGENTK_HELM_ADDITIONAL_CA_FILE_PATH=

################################################################################
# Built-in Target MCP Bridge
################################################################################

BUILTIN_TARGET_MCP_SERVER_NAME=acornops-target-agent
BUILTIN_TARGET_MCP_SERVER_URL=http://control-plane:8081/internal/v1/mcp
BUILTIN_TARGET_MCP_SERVER_DISPLAY_NAME='AcornOps Target Tools'

################################################################################
# Control Plane HA, Retention & Run Events
################################################################################

CONVERSATION_RETENTION_DAYS=30
CONVERSATION_RETENTION_JOB_INTERVAL_SECONDS=3600
TOOL_RESULT_ARTIFACT_RETENTION_DAYS=7
TOOL_RESULT_ARTIFACT_MAX_BYTES=2097152
TARGET_CHAT_REPORT_RETENTION_DAYS=30
RUN_EVENT_BUFFER_SIZE=200
PERSIST_RUN_EVENTS=true
CONTROL_PLANE_DISTRIBUTED_ROUTING_ENABLED=true
CONTROL_PLANE_AGENT_OWNER_TTL_SECONDS=90
CONTROL_PLANE_AGENT_SNAPSHOT_INTERVAL_SECONDS=60
AUTOMATION_RUNTIME_MODE=off
AUTOMATION_CANARY_WORKSPACE_IDS=
AUTOMATION_WORKER_INTERVAL_MS=1000
AGENT_WS_MAX_PAYLOAD_BYTES=3145728

################################################################################
# Execution Durability & Runtime Timeouts
################################################################################

EXECUTION_ENGINE_REDIS_URL=redis://:replace-me@cp-redis:6379/1
EXECUTION_DURABILITY_REDIS_URL=redis://:replace-me@cp-redis:6379/1
EXECUTION_DURABILITY_KEY_PREFIX=execution-engine
TOOL_CONTEXT_MAX_BYTES=12288
TOOL_CONTEXT_RUN_MAX_BYTES=49152
TOOL_GATEWAY_MAX_RESPONSE_BYTES=5242880
TERMINAL_RUN_TTL_SECONDS=3600
TERMINAL_COMMIT_RETENTION_SECONDS=86400
TERMINAL_COMMIT_RETRY_INTERVAL_SECONDS=5
STALE_ACTIVE_RUN_RECOVERY_ON_STARTUP=true
EE_READINESS_CHECK_TIMEOUT_MS=1000
RUN_ID_LOCK_TTL_SECONDS=900
ORCH_RETRY_MAX_ELAPSED_SECONDS=30
GATEWAY_STREAM_IDLE_TIMEOUT_SECONDS=60
TOOL_CALL_TIMEOUT_SECONDS=30
DISPATCH_REQUEST_TIMEOUT_SECONDS=10
MAX_REQUEST_BODY_BYTES=1000000

################################################################################
# LLM Gateway Secrets Store
################################################################################

SECRETS_BACKEND=database
SECRETS_CACHE_TTL_SEC=0
VAULT_ADDR=
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_MOUNT=secret
VAULT_PATH_PREFIX=acornops
VAULT_TIMEOUT_MS=5000
VAULT_VERIFY_TLS=true

################################################################################
# LLM Provider Endpoints
################################################################################

# Optional deployment-wide native API base URLs. Leave empty for provider defaults.
LLM_PROVIDER_OPENAI_BASE_URL=
LLM_PROVIDER_ANTHROPIC_BASE_URL=
LLM_PROVIDER_GEMINI_BASE_URL=

################################################################################
# MCP Egress Policy
################################################################################

MCP_EGRESS_ALLOWED_HOSTS=
MCP_EGRESS_ALLOW_PRIVATE_NETWORKS=false
MCP_EGRESS_ALLOW_LOCAL_ADDRESSES=false

################################################################################
# API Docs, JWKS Readiness & Rate Limits
################################################################################

CP_ENABLE_API_DOCS=false
EE_ENABLE_API_DOCS=false
GW_ENABLE_API_DOCS=false
LLM_GATEWAY_MAX_REQUEST_BODY_BYTES=1000000
JWKS_CACHE_TTL_SECONDS=300
JWKS_READINESS_MAX_STALENESS_SECONDS=900
REQUIRE_JWKS_READINESS=true
RATE_LIMIT_WINDOW_SECONDS=60
LLM_RATE_LIMIT_PER_WINDOW=100
TOOL_RATE_LIMIT_PER_WINDOW=200
REQUIRE_REDIS_RATE_LIMITS_IN_PRODUCTION=true

################################################################################
# Databases
################################################################################

CP_DB_USER=acornops
CP_DB_PASSWORD=replace-me
CP_DB_NAME=acornops_control_plane
GATEWAY_DB_USER=gateway_user
GATEWAY_DB_PASSWORD=replace-me
GATEWAY_DB_NAME=gateway

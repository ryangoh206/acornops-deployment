{
  "repo": "deployment",
  "version": 1,
  "executionContractVersion": 2,
  "workflowSchemaEpoch": "workflow-v2-greenfield-1",
  "runtimeDependencies": [
    "management-console",
    "control-plane",
    "execution-engine",
    "llm-gateway",
    "agentk",
    "agentv"
  ],
  "contractSurfaces": {
    "composeProfiles": ["local", "prod", "oidc-dex", "oidc-keycloak", "local-vault"],
    "publicHosts": ["console.acornops.dev", "docs.acornops.dev", "api.acornops.dev"],
    "publicRoutes": ["/", "/api/v1", "/api/v1/auth/oidc/callback", "/api/v1/auth/oidc/logout/start", "/api/v1/auth/oidc/logout/callback", "/admin/v1"],
    "envTracks": ["local", "vm", "k8s"],
    "oidcEnv": [
      "OIDC_ENABLED",
      "OIDC_ADMISSION_POLICY_JSON",
      "OIDC_END_SESSION_ENDPOINT_OVERRIDE",
      "OIDC_POST_LOGOUT_REDIRECT_URI"
    ],
    "oidcHelmValues": [
      "auth.oidc.enabled",
      "auth.oidc.clientSecret.existingSecret",
      "auth.oidc.clientSecret.key",
      "auth.oidc.authorizationEndpoint",
      "auth.oidc.tokenEndpoint",
      "auth.oidc.userInfoEndpoint",
      "auth.oidc.admission",
      "auth.oidc.logout.endSessionEndpointOverride",
      "auth.oidc.logout.postLogoutRedirectUri"
    ],
    "emailVerificationEnv": [
      "PASSWORD_EMAIL_VERIFICATION_REQUIRED",
      "PASSWORD_EMAIL_VERIFICATION_TOKEN_TTL_SECONDS",
      "PASSWORD_EMAIL_VERIFICATION_RESEND_WINDOW_SECONDS",
      "PASSWORD_SIGNUP_ALLOW_UNVERIFIED_EMAIL",
      "PASSWORD_RESET_ENABLED",
      "PASSWORD_RESET_TOKEN_TTL_SECONDS",
      "PASSWORD_RESET_REQUEST_WINDOW_SECONDS",
      "EMAIL_DELIVERY_MODE",
      "EMAIL_DELIVERY_ALLOW_LOG_IN_PRODUCTION",
      "EMAIL_FROM",
      "EMAIL_PUBLIC_BASE_URL",
      "MANAGEMENT_CONSOLE_BASE_URL",
      "SMTP_HOST",
      "SMTP_PORT",
      "SMTP_USERNAME",
      "SMTP_PASSWORD",
      "SMTP_SECURE",
      "SMTP_REQUIRE_TLS"
    ],
    "adminApiEnv": [
      "CONTROL_PLANE_ADMIN_API_ENABLED",
      "CONTROL_PLANE_ADMIN_TOKENS_JSON",
      "CONTROL_PLANE_ADMIN_AUTH_FAILURE_WINDOW_SECONDS",
      "CONTROL_PLANE_ADMIN_AUTH_FAILURE_MAX_ATTEMPTS"
    ],
    "externalIntegrationEnv": [
      "EXTERNAL_INTEGRATION_CLIENTS_JSON",
      "EXTERNAL_INTEGRATION_LINK_TOKEN_TTL_SECONDS",
      "EXTERNAL_INTEGRATION_LINK_TTL_SECONDS",
      "EXTERNAL_INTEGRATION_LINK_TOKEN_RETENTION_DAYS"
    ],
    "workspacePlanEnv": ["WORKSPACE_PLANS_CONFIG_JSON"],
    "auditLoggingEnv": [
      "WORKSPACE_AUDIT_LOGGING_MODE",
      "WORKSPACE_AUDIT_RETENTION_DAYS"
    ],
    "aiPolicyEnv": [
      "LLM_DEFAULT_PROVIDER",
      "LLM_DEFAULT_MODEL",
      "LLM_ALLOWED_PROVIDERS",
      "LLM_ALLOWED_PROVIDER_MODELS",
      "LLM_REASONING_SUMMARIES_ENABLED",
      "LLM_ALLOWED_REASONING_SUMMARY_MODES",
      "LLM_ALLOWED_REASONING_EFFORTS"
    ],
    "workflowRuntimePolicyEnv": [
      "AGENT_MAX_RUNTIME_MS",
      "TARGET_CHAT_REPORT_RETENTION_DAYS"
    ],
    "adminApiHelmValues": [
      "adminApi.enabled",
      "adminApi.ingress.enabled",
      "adminApi.tokens.existingSecretName",
      "adminApi.tokens.tokensJsonKey"
    ],
    "externalIntegrationHelmValues": [
      "secrets.keys.controlPlane.externalIntegrationClientsJson"
    ],
    "workspacePlanHelmValues": [
      "workspacePlans.defaultPlanKey",
      "workspacePlans.plans[].{key,name,quotas.members,quotas.kubernetesClusters,quotas.virtualMachines}"
    ],
    "auditLoggingHelmValues": [
      "auditLogging.mode",
      "auditLogging.retentionDays"
    ],
    "aiPolicyHelmValues": [
      "ai.defaultProvider",
      "ai.defaultModel",
      "ai.allowedProviders",
      "ai.allowedProviderModels",
      "ai.reasoningSummariesEnabled",
      "ai.allowedReasoningSummaryModes",
      "ai.allowedReasoningEfforts"
    ],
    "workflowRuntimePolicyHelmValues": [
      "agent.runtime.maxRuntimeMs",
      "components.controlPlane.reportArtifacts.maxRetentionDays"
    ],
    "additionalCaHelmValues": [
      "global.trust.additionalCaBundle.configMapKeyRef.name",
      "global.trust.additionalCaBundle.configMapKeyRef.key",
      "global.trust.additionalCaBundle.secretKeyRef.name",
      "global.trust.additionalCaBundle.secretKeyRef.key",
      "components.controlPlane.trust.additionalCaBundle.configMapKeyRef.name",
      "components.controlPlane.trust.additionalCaBundle.configMapKeyRef.key",
      "components.controlPlane.trust.additionalCaBundle.secretKeyRef.name",
      "components.controlPlane.trust.additionalCaBundle.secretKeyRef.key",
      "components.executionEngine.trust.additionalCaBundle.configMapKeyRef.name",
      "components.executionEngine.trust.additionalCaBundle.configMapKeyRef.key",
      "components.executionEngine.trust.additionalCaBundle.secretKeyRef.name",
      "components.executionEngine.trust.additionalCaBundle.secretKeyRef.key",
      "components.llmGateway.trust.additionalCaBundle.configMapKeyRef.name",
      "components.llmGateway.trust.additionalCaBundle.configMapKeyRef.key",
      "components.llmGateway.trust.additionalCaBundle.secretKeyRef.name",
      "components.llmGateway.trust.additionalCaBundle.secretKeyRef.key"
    ],
    "additionalCaRuntimeEnv": [
      "ADDITIONAL_CA_BUNDLE_FILE",
      "NODE_EXTRA_CA_CERTS",
      "ADDITIONAL_CA_BUNDLE_SOURCE_PATH",
      "ACORNOPS_AGENT_ADDITIONAL_CA_BUNDLE_FILE"
    ],
    "ingressNetworkPolicyHelmValues": [
      "exposure.ingress.enabled",
      "networkPolicies.enabled",
      "networkPolicies.ingressController.from",
      "components.managementConsole.service.targetPort",
      "components.controlPlane.service.targetPort"
    ],
    "privateControlPlaneEgressHelmValues": [
      "networkPolicies.oidc.to",
      "networkPolicies.oidc.ports",
      "networkPolicies.webhooks.to",
      "networkPolicies.webhooks.ports",
      "components.controlPlane.webhookEgress.allowedPrivateHosts"
    ],
    "privateWebhookRuntimeEnv": ["WEBHOOK_EGRESS_ALLOWED_PRIVATE_HOSTS_JSON"],
    "durableWebhookDeliveryHelmValues": [
      "components.controlPlane.webhookDelivery.enabled",
      "components.controlPlane.webhookDelivery.batchSize",
      "components.controlPlane.webhookDelivery.concurrency",
      "components.controlPlane.webhookDelivery.perOriginConcurrency",
      "components.controlPlane.webhookDelivery.maxAttempts",
      "components.controlPlane.webhookDelivery.maxRetryAgeSeconds",
      "components.controlPlane.webhookDelivery.maxPayloadBytes",
      "components.controlPlane.webhookDelivery.maxSubscriptionsPerWorkspace"
    ],
    "durableWebhookDeliveryRuntimeEnv": [
      "WEBHOOK_WORKER_ENABLED",
      "WEBHOOK_WORKER_BATCH_SIZE",
      "WEBHOOK_WORKER_CONCURRENCY",
      "WEBHOOK_WORKER_PER_ORIGIN_CONCURRENCY",
      "WEBHOOK_MAX_ATTEMPTS",
      "WEBHOOK_MAX_RETRY_AGE_SECONDS",
      "WEBHOOK_MAX_PAYLOAD_BYTES",
      "WEBHOOK_MAX_SUBSCRIPTIONS_PER_WORKSPACE"
    ],
    "agentKRolloutEnv": [
      "ACORNOPS_AGENT_PLATFORM_URL",
      "ACORNOPS_CLUSTER_ID",
      "ACORNOPS_AGENT_KEY"
    ],
    "agentKInstallHelmValues": [
      "targetAgents.agentk.helm.chartRef",
      "targetAgents.agentk.helm.chartVersion"
    ],
    "agentVLocalEnv": [
      "ACORNOPS_AGENT_PLATFORM_URL",
      "ACORNOPS_AGENT_ALLOW_INSECURE_TRANSPORT",
      "ACORNOPS_TARGET_ID",
      "ACORNOPS_AGENT_KEY",
      "ACORNOPS_AGENT_TARGET_TYPE",
      "ACORNOPS_VM_COLLECTOR_MODE",
      "ACORNOPS_VM_OS_FAMILY",
      "ACORNOPS_VM_SERVICE_MANAGER",
      "ACORNOPS_VM_ALLOWED_LOG_UNITS",
      "ACORNOPS_AGENT_WRITE_ENABLED"
    ],
    "localAgentInsecureTransportEnv": ["ACORNOPS_AGENT_ALLOW_INSECURE_TRANSPORT"],
    "starterAutomationProvisioning": {
      "scope": "every workspace",
      "developmentFixtureIndependent": true,
      "seedDevelopmentDataPurpose": "optional local owner, workspace, Kubernetes target, target settings, and AgentK registration"
    },
    "databaseEpoch": {
      "mode": "greenfield_reset",
      "preservesPreReleaseData": false
    },
    "catalogEnv": [
      "CATALOG_OFFICIAL_REGISTRY_ENABLED",
      "CATALOG_OFFICIAL_REGISTRY_URL",
      "CATALOG_WORKSPACE_MANAGED_SOURCES_ENABLED",
      "CATALOG_BOOTSTRAP_SOURCES_JSON"
    ],
    "mcpPatEnv": [
      "REMOTE_MCP_ENABLED",
      "MCP_CONNECTION_RATE_LIMIT_PER_WINDOW",
      "RATE_LIMIT_WINDOW_SECONDS"
    ],
    "catalogHelmValues": [
      "components.llmGateway.catalog.officialRegistryEnabled",
      "components.llmGateway.catalog.officialRegistryUrl",
      "components.llmGateway.catalog.allowWorkspaceManagedSources",
      "components.llmGateway.catalog.bootstrapSources[].{workspaceId,displayName,baseUrl,networkRoute,adapterBasePath,enabled,auth.{type,headerName,secretKeyRef.{name,key}}}",
      "components.llmGateway.mcpEgress.{allowedHosts,allowPrivateNetworks,allowLocalAddresses}",
      "components.llmGateway.trust.additionalCaBundle"
    ],
    "mcpPatHelmValues": [
      "components.llmGateway.remoteMcp.enabled",
      "components.llmGateway.rateLimits.mcpConnectionPerWindow"
    ],
    "mcpPatAlertFiles": [
      "observability/prometheus/alerts/llm-gateway.rules.yaml",
      "observability/prometheus/alerts/control-plane-automation.rules.yaml"
    ],
    "internalTransportTlsValues": [
      "internalTransport.tls.enabled",
      "internalTransport.tls.requireClientCert",
      "internalTransport.tls.ca.secretName",
      "internalTransport.tls.ca.key",
      "internalTransport.tls.certificates.controlPlane.secretName",
      "internalTransport.tls.certificates.executionEngine.secretName",
      "internalTransport.tls.certificates.llmGateway.secretName"
    ],
    "releaseMetadata": "release/stack-versions.yaml"
  }
}
